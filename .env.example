GOOGLE_API_KEY=your-google-api-key-here

# LLM Configuration — Gemini only
# Models: gemini-2.5-flash, gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.1

# RAG Configuration (embeddings are local HuggingFace all-MiniLM-L6-v2)
CHROMA_PERSIST_DIR=./rag_store
# Optional: external project folder(s) to ingest read-only (their locators /
# page objects / tests are added to the knowledge base; the folders are never
# modified). Comma- or :-separated. Run --rebuild-rag after changing this.
# EXTERNAL_CONTEXT_DIRS=/path/to/your/qa-automation-framework

# Target Application
TARGET_BASE_URL=https://your-app-url-here
HEADLESS_BROWSER=true

# Execution
MAX_RETRY_ATTEMPTS=3
DEBUG_MODE=true

# Trello Integration (optional — leave blank to disable)
TRELLO_API_KEY=your-trello-api-key-here
TRELLO_TOKEN=your-trello-token-here
TRELLO_BOARD_NAME=AI Test Agent
TRELLO_LIST_NAME=To Do
